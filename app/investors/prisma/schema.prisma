// Vergil Investors Portal Database Schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Financial Metrics
model Metric {
  id        String   @id @default(cuid())
  type      String   // revenue, growth, users, retention, etc.
  value     Float
  label     String
  unit      String?  // $, %, K, M, etc.
  
  // Trend data
  trendDirection String?   // up, down, stable
  trendPercentage Float?
  
  // Time tracking
  timestamp DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Metadata
  source    String?  // API, manual, calculated
  notes     String?
  
  @@unique([type, label])
  @@index([type])
  @@index([timestamp])
}

// Chart Data Storage
model ChartData {
  id        String   @id @default(cuid())
  chartType String   // revenue-growth, performance-metrics, user-acquisition, etc.
  data      Json     // Flexible JSON storage for various chart formats
  
  // Time range
  startDate DateTime?
  endDate   DateTime?
  
  // Metadata
  title     String?
  description String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([chartType])
  @@index([createdAt])
}

// Financial Reports
model Report {
  id          String   @id @default(cuid())
  title       String
  description String?
  
  // File information
  fileUrl     String   // S3 URL or local path
  fileName    String
  fileSize    Int?     // in bytes
  mimeType    String?
  
  // Categorization
  category    String   // quarterly, annual, investor-update, etc.
  type        String?  // pdf, xlsx, docx
  quarter     String?  // Q1, Q2, Q3, Q4
  year        Int?
  
  // Access control
  isPublic    Boolean  @default(false)
  accessLevel String   @default("investor") // investor, board, public
  
  // Metadata
  author      String?
  tags        String[] // Array of tags for filtering
  
  uploadedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([category])
  @@index([year, quarter])
  @@index([uploadedAt])
}

// Company Updates/News
model Update {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  summary     String?
  
  // Categorization
  category    String   // product, financial, team, partnership, etc.
  priority    String   @default("normal") // urgent, high, normal, low
  
  // Media
  imageUrl    String?
  attachments Json?    // Array of attachment URLs
  
  // Publishing
  publishedAt DateTime?
  isPublished Boolean  @default(false)
  author      String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([category])
  @@index([publishedAt])
  @@index([isPublished])
}

// Investor Access Logs
model AccessLog {
  id         String   @id @default(cuid())
  userId     String
  userEmail  String
  action     String   // login, view-report, download, etc.
  resource   String?  // What was accessed
  ipAddress  String?
  userAgent  String?
  
  timestamp  DateTime @default(now())
  
  @@index([userId])
  @@index([userEmail])
  @@index([action])
  @@index([timestamp])
}

// API Keys for External Services
model ApiKey {
  id          String   @id @default(cuid())
  name        String   @unique
  key         String   @unique
  description String?
  
  // Permissions
  permissions Json     // Array of allowed actions
  rateLimit   Int?     // Requests per minute
  
  // Usage tracking
  lastUsedAt  DateTime?
  usageCount  Int      @default(0)
  
  // Status
  isActive    Boolean  @default(true)
  expiresAt   DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([key])
  @@index([isActive])
}

// Data Change Audit Trail
model AuditLog {
  id          String   @id @default(cuid())
  tableName   String   // Which table was modified
  recordId    String   // ID of the modified record
  action      String   // create, update, delete
  userId      String?  // Who made the change
  
  // Change details
  oldValues   Json?    // Previous values
  newValues   Json?    // New values
  
  timestamp   DateTime @default(now())
  
  @@index([tableName, recordId])
  @@index([userId])
  @@index([timestamp])
}